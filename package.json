{
  "name": "al-huffaz-portal-v3",
  "version": "0.1.0",
  "private": true,
  "description": "Al-Huffaz Education System Portal — modern Next.js rewrite deployed to Cloudflare Pages with Supabase backend.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "pages:build": "npx @cloudflare/next-on-pages@latest",
    "pages:preview": "npm run pages:build && npx wrangler pages dev .vercel/output/static",
    "pages:deploy": "npm run pages:build && npx wrangler pages deploy .vercel/output/static"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.45.4",
    "drizzle-orm": "^0.36.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.5",
    "@cloudflare/workers-types": "^4.20241022.0",
    "@types/node": "^22.7.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.28.0",
    "eslint": "^9.12.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vercel": "^37.0.0",
    "wrangler": "^3.80.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
