# Supabase — get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — never expose to the client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Al-Huffaz Education Portal"
NEXT_PUBLIC_CURRENCY=PKR
NEXT_PUBLIC_CURRENCY_SYMBOL=Rs.

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@your-domain.com

# Payment gateway — fill once chosen (JazzCash / Easypaisa / Stripe)
PAYMENT_PROVIDER=
PAYMENT_MERCHANT_ID=
PAYMENT_API_KEY=
PAYMENT_API_SECRET=
PAYMENT_WEBHOOK_SECRET=
